<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chain Management System</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark shadow">
        <div class="container">
            <span class="navbar-brand fw-bold">
                Chain Management System
            </span>
        </div>
    </nav>

    <div class="container mt-4">

        <h2 class="text-center mb-4">
            Chain Management Dashboard
        </h2>

        <!-- Dashboard Cards -->
        <div class="row mb-4">

            <div class="col-md-4 mb-3">
                <div class="card bg-primary text-white shadow border-0">
                    <div class="card-body text-center">
                        <h5>Total Chains</h5>
                        <h2><%= counts.totalChains %></h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card bg-success text-white shadow border-0">
                    <div class="card-body text-center">
                        <h5>Active Chains</h5>
                        <h2><%= counts.activeChains %></h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card bg-danger text-white shadow border-0">
                    <div class="card-body text-center">
                        <h5>Inactive Chains</h5>
                        <h2><%= counts.inactiveChains %></h2>
                    </div>
                </div>
            </div>

        </div>

        <!-- Search Form -->
        <form action="/search" method="GET" class="mb-3">
            <div class="input-group">

                <input
                    type="text"
                    name="keyword"
                    class="form-control"
                    placeholder="Search Company Name">

                <button class="btn btn-success shadow" type="submit">
                    Search
                </button>

                <a href="/" class="btn btn-secondary shadow">
                    Reset
                </a>

            </div>
        </form>

        <!-- Filter Form -->
        <form action="/filter" method="GET" class="mb-3">
            <div class="input-group">

                <select name="group_id" class="form-select">

                    <% groups.forEach(group => { %>

                        <option value="<%= group.group_id %>">
                            <%= group.group_name %>
                        </option>

                    <% }) %>

                </select>

                <button class="btn btn-info shadow" type="submit">
                    Filter
                </button>

            </div>
        </form>

        <!-- Add Button -->
        <div class="mb-3">
            <a href="/chains/add" class="btn btn-primary shadow">
                Add New Chain
            </a>
        </div>

        <!-- Table -->
        <div class="table-responsive">

            <table class="table table-bordered table-hover shadow">

                <thead class="table-dark">

                    <tr>
                        <th>ID</th>
                        <th>Company Name</th>
                        <th>GSTN Number</th>
                        <th>Group</th>
                        <th width="180">Action</th>
                    </tr>

                </thead>

                <tbody>

                    <% if(chains.length===0){ %>

                        <tr>

                            <td colspan="5" class="text-center text-danger fw-bold">
                                No Chains Found
                            </td>

                        </tr>

                    <% } else { %>

                        <% chains.forEach(chain => { %>

                            <tr>

                                <td><%= chain.chain_id %></td>
                                <td><%= chain.company_name %></td>
                                <td><%= chain.gstn_number %></td>
                                <td><%= chain.group_name %></td>

                                <td>

                                    <a href="/chains/edit/<%= chain.chain_id %>"
                                        class="btn btn-warning btn-sm shadow">
                                        Edit
                                    </a>

                                    <a href="/chains/delete/<%= chain.chain_id %>"
                                        class="btn btn-danger btn-sm shadow"
                                        onclick="return confirm('Are you sure you want to delete this chain?')">
                                        Delete
                                    </a>

                                </td>

                            </tr>

                        <% }) %>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

    <!-- Footer -->
    <footer class="text-center mt-5 mb-3">

        <hr>

        <p class="text-muted">
            © 2026 Chain Management System | Developed by Sakshi Gawade
        </p>

    </footer>

</body>

</html>